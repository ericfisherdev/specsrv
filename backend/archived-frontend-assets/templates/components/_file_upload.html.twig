<div 
    x-data="fileUpload()" 
    class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-gray-400 transition-colors"
    x-bind:class="{ 'border-blue-500 bg-blue-50': isDragging }"
    x-on:dragover.prevent="isDragging = true"
    x-on:dragleave.prevent="isDragging = false"
    x-on:drop.prevent="handleDrop($event)"
>
    <!-- Upload Area -->
    <div x-show="!uploading && files.length === 0">
        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="mt-4">
            <label for="file-upload" class="cursor-pointer">
                <span class="mt-2 block text-sm font-medium text-gray-900">
                    Drop files here or click to browse
                </span>
                <input 
                    id="file-upload" 
                    name="files[]" 
                    type="file" 
                    class="sr-only" 
                    multiple
                    x-on:change="handleFileSelect($event)"
                >
            </label>
            <p class="mt-1 text-xs text-gray-500">
                PNG, JPG, PDF, MD, TXT up to 10MB
            </p>
        </div>
    </div>
    
    <!-- Upload Progress -->
    <div x-show="uploading" class="space-y-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center">
                <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-sm font-medium text-gray-900" x-text="uploadStatus"></span>
            </div>
            <span class="text-xs text-gray-500" x-text="`${uploadProgress}%`"></span>
        </div>
        
        <!-- Overall Progress Bar -->
        <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-blue-600 h-2 rounded-full transition-all duration-300" x-bind:style="`width: ${uploadProgress}%`"></div>
        </div>
        
        <!-- Individual File Progress -->
        <div x-show="currentFiles.length > 0" class="space-y-2">
            <template x-for="file in currentFiles" :key="file.name">
                <div class="flex items-center space-x-3 p-2 bg-gray-50 rounded">
                    <div class="flex-shrink-0">
                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900 truncate" x-text="file.name"></p>
                        <div class="flex items-center space-x-2">
                            <div class="flex-1 bg-gray-200 rounded-full h-1">
                                <div class="bg-blue-600 h-1 rounded-full transition-all duration-300" x-bind:style="`width: ${file.progress || 0}%`"></div>
                            </div>
                            <span class="text-xs text-gray-500" x-text="formatFileSize(file.size)"></span>
                        </div>
                    </div>
                    <div class="flex-shrink-0">
                        <span x-show="file.progress === 100" class="text-green-500">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                        </span>
                        <span x-show="file.error" class="text-red-500">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                        </span>
                    </div>
                </div>
            </template>
        </div>
        
        <!-- Upload Speed and ETA -->
        <div x-show="uploadSpeed > 0" class="flex justify-between text-xs text-gray-500">
            <span x-text="`Speed: ${formatSpeed(uploadSpeed)}`"></span>
            <span x-show="uploadETA > 0" x-text="`ETA: ${formatTime(uploadETA)}`"></span>
        </div>
    </div>
    
    <!-- File List -->
    <div x-show="files.length > 0 && !uploading" class="mt-4 space-y-2">
        <h4 class="text-sm font-medium text-gray-900 text-left">Uploaded Files:</h4>
        <template x-for="file in files" :key="file.filename">
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div class="flex items-center space-x-3">
                    <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                    </svg>
                    <div class="text-left">
                        <p class="text-sm font-medium text-gray-900" x-text="file.original_name"></p>
                        <p class="text-xs text-gray-500" x-text="formatFileSize(file.size)"></p>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <a 
                        x-bind:href="`{{ path('app_file_download', {'filename': '__FILENAME__'}) }}`.replace('__FILENAME__', file.filename)"
                        class="text-blue-600 hover:text-blue-500 text-sm"
                        download
                    >
                        Download
                    </a>
                    <button 
                        x-on:click="removeFile(file.filename)"
                        class="text-red-600 hover:text-red-500 text-sm"
                    >
                        Delete
                    </button>
                </div>
            </div>
        </template>
    </div>
    
    <!-- Error Messages -->
    <div x-show="errors.length > 0" class="mt-4 space-y-2">
        <template x-for="error in errors" :key="error.filename">
            <div class="p-3 bg-red-50 border border-red-200 rounded-lg">
                <div class="flex">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    <div class="ml-3">
                        <p class="text-sm text-red-800">
                            <span class="font-medium" x-text="error.filename"></span>: 
                            <span x-text="error.error"></span>
                        </p>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>

<script>
function fileUpload() {
    return {
        files: [],
        errors: [],
        uploading: false,
        uploadProgress: 0,
        uploadStatus: 'Preparing upload...',
        currentFiles: [],
        uploadSpeed: 0,
        uploadETA: 0,
        uploadStartTime: 0,
        totalBytes: 0,
        uploadedBytes: 0,
        isDragging: false,
        
        handleDrop(event) {
            this.isDragging = false;
            const files = Array.from(event.dataTransfer.files);
            this.uploadFiles(files);
        },
        
        handleFileSelect(event) {
            const files = Array.from(event.target.files);
            this.uploadFiles(files);
        },
        
        async uploadFiles(files) {
            this.uploading = true;
            this.uploadProgress = 0;
            this.uploadStatus = 'Preparing upload...';
            this.errors = [];
            this.uploadStartTime = Date.now();
            this.totalBytes = Array.from(files).reduce((total, file) => total + file.size, 0);
            this.uploadedBytes = 0;
            
            // Initialize currentFiles with progress tracking
            this.currentFiles = Array.from(files).map(file => ({
                name: file.name,
                size: file.size,
                progress: 0,
                error: false
            }));
            
            // Use XMLHttpRequest for progress tracking
            return new Promise((resolve, reject) => {
                const xhr = new XMLHttpRequest();
                const formData = new FormData();
                
                files.forEach(file => {
                    formData.append('files[]', file);
                });
                
                // Add project/task context if available
                const projectId = document.querySelector('[data-project-id]')?.dataset.projectId;
                const taskId = document.querySelector('[data-task-id]')?.dataset.taskId;
                
                if (projectId) formData.append('project_id', projectId);
                if (taskId) formData.append('task_id', taskId);
                
                // Track upload progress
                xhr.upload.addEventListener('progress', (e) => {
                    if (e.lengthComputable) {
                        const percentComplete = (e.loaded / e.total) * 100;
                        this.uploadProgress = Math.round(percentComplete);
                        this.uploadedBytes = e.loaded;
                        
                        // Calculate upload speed and ETA
                        const elapsed = (Date.now() - this.uploadStartTime) / 1000; // seconds
                        if (elapsed > 1) {
                            this.uploadSpeed = this.uploadedBytes / elapsed; // bytes per second
                            const remaining = this.totalBytes - this.uploadedBytes;
                            this.uploadETA = remaining / this.uploadSpeed; // seconds remaining
                        }
                        
                        // Update individual file progress (simplified)
                        const progressPerFile = percentComplete / this.currentFiles.length;
                        this.currentFiles.forEach((file, index) => {
                            if (percentComplete >= (index + 1) * progressPerFile) {
                                file.progress = 100;
                            } else if (percentComplete > index * progressPerFile) {
                                file.progress = Math.round(percentComplete - (index * progressPerFile));
                            }
                        });
                        
                        // Update status message
                        if (percentComplete < 50) {
                            this.uploadStatus = 'Uploading files...';
                        } else if (percentComplete < 90) {
                            this.uploadStatus = 'Processing files...';
                        } else {
                            this.uploadStatus = 'Finalizing upload...';
                        }
                    }
                });
                
                xhr.addEventListener('load', () => {
                    try {
                        const result = JSON.parse(xhr.responseText);
                        
                        if (result.success && result.uploaded_files) {
                            this.files.push(...result.uploaded_files);
                            this.uploadStatus = `Successfully uploaded ${result.uploaded_files.length} file(s)`;
                        }
                        
                        if (result.errors) {
                            this.errors.push(...result.errors);
                            // Mark failed files
                            result.errors.forEach(error => {
                                const file = this.currentFiles.find(f => f.name === error.filename);
                                if (file) {
                                    file.error = true;
                                    file.progress = 0;
                                }
                            });
                        }
                        
                        this.uploadProgress = 100;
                        
                        // Trigger refresh of parent component if needed
                        this.$dispatch('files-uploaded', { files: result.uploaded_files || [] });
                        
                        resolve(result);
                    } catch (error) {
                        this.errors.push({
                            filename: 'Upload',
                            error: 'Invalid server response'
                        });
                        reject(error);
                    } finally {
                        setTimeout(() => {
                            this.uploading = false;
                            this.uploadProgress = 0;
                            this.currentFiles = [];
                            this.uploadSpeed = 0;
                            this.uploadETA = 0;
                        }, 2000);
                    }
                });
                
                xhr.addEventListener('error', () => {
                    this.errors.push({
                        filename: 'Upload',
                        error: 'Network error occurred'
                    });
                    
                    // Mark all files as failed
                    this.currentFiles.forEach(file => {
                        file.error = true;
                        file.progress = 0;
                    });
                    
                    setTimeout(() => {
                        this.uploading = false;
                        this.uploadProgress = 0;
                        this.currentFiles = [];
                        this.uploadSpeed = 0;
                        this.uploadETA = 0;
                    }, 2000);
                    
                    reject(new Error('Network error'));
                });
                
                xhr.open('POST', '{{ path('app_file_upload') }}');
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.send(formData);
            });
        },
        
        async removeFile(filename) {
            if (!confirm('Are you sure you want to delete this file?')) {
                return;
            }
            
            try {
                const response = await fetch(`{{ path('app_file_delete', {'filename': '__FILENAME__'}) }}`.replace('__FILENAME__', filename), {
                    method: 'DELETE',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                const result = await response.json();
                
                if (result.success) {
                    this.files = this.files.filter(file => file.filename !== filename);
                    this.$dispatch('file-deleted', { filename });
                }
                
            } catch (error) {
                console.error('Failed to delete file:', error);
            }
        },
        
        formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        },
        
        formatSpeed(bytesPerSecond) {
            if (bytesPerSecond === 0) return '0 B/s';
            const k = 1024;
            const sizes = ['B/s', 'KB/s', 'MB/s', 'GB/s'];
            const i = Math.floor(Math.log(bytesPerSecond) / Math.log(k));
            return parseFloat((bytesPerSecond / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        },
        
        formatTime(seconds) {
            if (seconds < 60) return Math.round(seconds) + 's';
            if (seconds < 3600) return Math.floor(seconds / 60) + 'm ' + Math.round(seconds % 60) + 's';
            return Math.floor(seconds / 3600) + 'h ' + Math.floor((seconds % 3600) / 60) + 'm';
        }
    }
}
</script>