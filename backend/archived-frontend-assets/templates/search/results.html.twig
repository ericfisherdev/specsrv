{% extends 'base.html.twig' %}

{% block title %}Search Results - {{ parent() }}{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Search Results</h1>
        {% if query %}
            <p class="mt-2 text-gray-600">Results for "<span class="font-medium">{{ query }}</span>"</p>
        {% endif %}
    </div>

    <!-- Advanced Search Filters -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8" x-data="searchFilters()" x-init="initFilters()">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-medium text-gray-900">Advanced Filters</h2>
            <button 
                @click="toggleFilters()"
                class="text-sm text-blue-600 hover:text-blue-500 font-medium"
                x-text="showFilters ? 'Hide Filters' : 'Show Filters'"
            ></button>
        </div>

        <div x-show="showFilters" x-transition class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
            <!-- Search Query -->
            <div>
                <label for="search-query" class="block text-sm font-medium text-gray-700 mb-1">Search</label>
                <input 
                    type="text" 
                    id="search-query"
                    x-model="filters.query"
                    value="{{ filters.query }}"
                    placeholder="Search tasks..."
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
            </div>

            <!-- Project Filter -->
            <div>
                <label for="project-filter" class="block text-sm font-medium text-gray-700 mb-1">Project</label>
                <select 
                    id="project-filter"
                    x-model="filters.project_id"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                    <option value="">All Projects</option>
                    {% for project in user_projects %}
                        <option value="{{ project.id }}" {% if filters.project_id == project.id %}selected{% endif %}>
                            {{ project.title }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <!-- Status Filter -->
            <div>
                <label for="status-filter" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select 
                    id="status-filter"
                    x-model="filters.status"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                    <option value="">All Statuses</option>
                    {% for status in statuses %}
                        <option value="{{ status }}" {% if filters.status == status %}selected{% endif %}>
                            {{ status|title|replace({'_': ' '}) }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <!-- Priority Filter -->
            <div>
                <label for="priority-filter" class="block text-sm font-medium text-gray-700 mb-1">Priority</label>
                <select 
                    id="priority-filter"
                    x-model="filters.priority"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                    <option value="">All Priorities</option>
                    {% for priority in priorities %}
                        <option value="{{ priority }}" {% if filters.priority == priority %}selected{% endif %}>
                            {{ priority|title }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <!-- Date Range Filter -->
            <div>
                <label for="date-filter" class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
                <select 
                    id="date-filter"
                    x-model="filters.date_range"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >
                    <option value="">All Time</option>
                    {% for key, label in date_ranges %}
                        <option value="{{ key }}" {% if filters.date_range == key %}selected{% endif %}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="mt-4 flex items-center space-x-3" x-show="showFilters" x-transition>
            <button 
                @click="applyFilters()"
                x-bind:disabled="loading"
                class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
            >
                <span x-show="!loading">Apply Filters</span>
                <span x-show="loading" class="flex items-center">
                    <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Searching...
                </span>
            </button>
            <button 
                @click="clearFilters()"
                class="px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-200"
            >
                Clear All
            </button>
        </div>
    </div>

    <!-- Results -->
    <div class="space-y-8">
        <!-- Tasks Results -->
        <div>
            <h2 class="text-xl font-semibold text-gray-900 mb-4">
                Tasks 
                <span class="text-sm font-normal text-gray-500">
                    ({{ tasks|length }} result{{ tasks|length != 1 ? 's' : '' }})
                </span>
            </h2>
            
            {% if tasks|length > 0 %}
                <div class="grid gap-4">
                    {% for task in tasks %}
                        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                            <div class="flex items-start justify-between">
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-lg font-medium text-gray-900 mb-2">
                                        <a href="{{ path('app_task_detail', {'id': task.id}) }}" class="hover:text-blue-600">
                                            {{ task.title }}
                                        </a>
                                    </h3>
                                    {% if task.description %}
                                        <p class="text-sm text-gray-600 mb-3">{{ task.description|slice(0, 150) }}{% if task.description|length > 150 %}...{% endif %}</p>
                                    {% endif %}
                                    <div class="flex items-center space-x-4 text-sm text-gray-500">
                                        <span class="flex items-center">
                                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                            {{ task.project.title }}
                                        </span>
                                        <span>{{ task.createdAt|date('M j, Y') }}</span>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-2 ml-4">
                                    <span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded-full
                                        {% if task.status == 'completed' %}text-green-700 bg-green-100
                                        {% elseif task.status == 'in_progress' %}text-blue-700 bg-blue-100
                                        {% elseif task.status == 'review' %}text-yellow-700 bg-yellow-100
                                        {% else %}text-gray-700 bg-gray-100{% endif %}">
                                        {{ task.status|replace({'_': ' '})|title }}
                                    </span>
                                    <span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded-full
                                        {% if task.priority == 'critical' %}text-red-700 bg-red-100
                                        {% elseif task.priority == 'high' %}text-orange-700 bg-orange-100
                                        {% elseif task.priority == 'medium' %}text-yellow-700 bg-yellow-100
                                        {% else %}text-green-700 bg-green-100{% endif %}">
                                        {{ task.priority|title }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-12">
                    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    <h3 class="mt-2 text-sm font-medium text-gray-900">No tasks found</h3>
                    <p class="mt-1 text-sm text-gray-500">Try adjusting your search criteria or creating a new task.</p>
                </div>
            {% endif %}
        </div>

        <!-- Projects Results -->
        {% if projects|length > 0 %}
            <div>
                <h2 class="text-xl font-semibold text-gray-900 mb-4">
                    Projects 
                    <span class="text-sm font-normal text-gray-500">
                        ({{ projects|length }} result{{ projects|length != 1 ? 's' : '' }})
                    </span>
                </h2>
                
                <div class="grid gap-4">
                    {% for project in projects %}
                        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                            <div class="flex items-start justify-between">
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-lg font-medium text-gray-900 mb-2">
                                        <a href="{{ path('app_project_detail', {'id': project.id}) }}" class="hover:text-blue-600">
                                            {{ project.title }}
                                        </a>
                                    </h3>
                                    {% if project.description %}
                                        <p class="text-sm text-gray-600 mb-3">{{ project.description|slice(0, 150) }}{% if project.description|length > 150 %}...{% endif %}</p>
                                    {% endif %}
                                    <div class="flex items-center space-x-4 text-sm text-gray-500">
                                        <span>{{ project.createdAt|date('M j, Y') }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
</div>

<script>
function searchFilters() {
    return {
        showFilters: false,
        loading: false,
        filters: {
            query: '{{ filters.query }}',
            project_id: '{{ filters.project_id }}',
            status: '{{ filters.status }}',
            priority: '{{ filters.priority }}',
            date_range: '{{ filters.date_range }}'
        },

        initFilters() {
            // Show filters if any are currently applied
            const hasActiveFilters = this.filters.project_id || this.filters.status || 
                                   this.filters.priority || this.filters.date_range;
            this.showFilters = hasActiveFilters;
        },

        toggleFilters() {
            this.showFilters = !this.showFilters;
        },

        async applyFilters() {
            this.loading = true;
            
            try {
                const params = new URLSearchParams();
                
                Object.entries(this.filters).forEach(([key, value]) => {
                    if (value) {
                        params.append(key === 'query' ? 'q' : key, value);
                    }
                });
                
                window.location.href = `{{ path('app_search') }}?${params.toString()}`;
                
            } catch (error) {
                console.error('Error applying filters:', error);
            } finally {
                this.loading = false;
            }
        },

        clearFilters() {
            this.filters = {
                query: '',
                project_id: '',
                status: '',
                priority: '',
                date_range: ''
            };
            
            // Redirect to clear all filters
            window.location.href = '{{ path('app_search') }}';
        }
    };
}
</script>
{% endblock %}