{% extends 'base.html.twig' %}

{% block title %}Edit Task - {{ parent() }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Task</h1>
        
        <form hx-post="{{ path('app_task_edit', {'id': task.id}) }}" hx-swap="none">
            <div class="mb-6">
                <label for="task-title" class="block text-sm font-medium text-gray-700 mb-2">Task Title</label>
                <input 
                    type="text" 
                    id="task-title" 
                    name="title"
                    value="{{ task.title }}"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    required
                >
            </div>
            
            <div class="mb-6">
                <label for="task-description" class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                <textarea 
                    id="task-description" 
                    name="description"
                    rows="4"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                >{{ task.description }}</textarea>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label for="task-priority" class="block text-sm font-medium text-gray-700 mb-2">Priority</label>
                    <select 
                        id="task-priority" 
                        name="priority"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    >
                        <option value="low" {% if task.priority == 'low' %}selected{% endif %}>Low</option>
                        <option value="medium" {% if task.priority == 'medium' %}selected{% endif %}>Medium</option>
                        <option value="high" {% if task.priority == 'high' %}selected{% endif %}>High</option>
                        <option value="critical" {% if task.priority == 'critical' %}selected{% endif %}>Critical</option>
                    </select>
                </div>
                
                <div>
                    <label for="task-status" class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                    <select 
                        id="task-status" 
                        name="status"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    >
                        <option value="backlog" {% if task.status == 'backlog' %}selected{% endif %}>Backlog</option>
                        <option value="todo" {% if task.status == 'todo' %}selected{% endif %}>Todo</option>
                        <option value="in_progress" {% if task.status == 'in_progress' %}selected{% endif %}>In Progress</option>
                        <option value="review" {% if task.status == 'review' %}selected{% endif %}>Review</option>
                        <option value="completed" {% if task.status == 'completed' %}selected{% endif %}>Completed</option>
                    </select>
                </div>
            </div>
            
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Project</label>
                <div class="px-3 py-2 border border-gray-300 rounded-md bg-gray-50">
                    {{ task.project.title }}
                </div>
                <p class="mt-1 text-sm text-gray-500">Project cannot be changed after task creation</p>
            </div>

            <!-- File Management Section -->
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Attached Files</label>
                
                <!-- Existing Files -->
                <div class="mb-4">
                    {% if task.files|length > 0 %}
                        <div class="space-y-2" x-data="{ files: {{ task.files|json_encode }} }">
                            <template x-for="file in files" :key="file.id">
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                    <div class="flex items-center space-x-3">
                                        <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                                        </svg>
                                        <div>
                                            <p class="text-sm font-medium text-gray-900" x-text="file.filename"></p>
                                            <p class="text-xs text-gray-500" x-text="new Date(file.createdAt.date).toLocaleDateString()"></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-2">
                                        <a 
                                            :href="`{{ path('app_file_download', {'id': '__ID__'}) }}`.replace('__ID__', file.id)"
                                            class="text-blue-600 hover:text-blue-500 text-sm"
                                            download
                                        >
                                            Download
                                        </a>
                                        <button 
                                            @click="removeFile(file.id, $event.target)"
                                            class="text-red-600 hover:text-red-500 text-sm"
                                            type="button"
                                        >
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-sm">No files currently attached</p>
                    {% endif %}
                </div>

                <!-- File Upload Area -->
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-4" x-data="fileUploadEdit()">
                    <div x-show="!uploading && newFiles.length === 0">
                        <div class="text-center">
                            <svg class="mx-auto h-8 w-8 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div class="mt-2">
                                <label for="edit-files" class="cursor-pointer">
                                    <span class="text-sm font-medium text-gray-900">
                                        Add more files
                                    </span>
                                    <input 
                                        id="edit-files" 
                                        name="files[]" 
                                        type="file" 
                                        class="sr-only" 
                                        multiple
                                        @change="handleFileSelect($event)"
                                    >
                                </label>
                                <p class="mt-1 text-xs text-gray-500">
                                    PNG, JPG, PDF, MD, TXT up to 10MB
                                </p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Upload Progress -->
                    <div x-show="uploading" class="text-center">
                        <div class="flex items-center justify-center">
                            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span class="text-sm text-gray-700">Uploading files...</span>
                        </div>
                    </div>
                    
                    <!-- File List for Upload -->
                    <div x-show="newFiles.length > 0 && !uploading" class="space-y-2">
                        <template x-for="file in newFiles" :key="file.name">
                            <div class="flex items-center justify-between p-2 bg-gray-100 rounded">
                                <span class="text-sm text-gray-700" x-text="file.name"></span>
                                <div class="flex items-center space-x-2">
                                    <button type="button" @click="uploadFile(file)" class="text-blue-600 hover:text-blue-800 text-sm">Upload</button>
                                    <button type="button" @click="removeNewFile(file)" class="text-red-600 hover:text-red-800 text-sm">Remove</button>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            <!-- Git Links Management Section -->
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Git Links</label>
                
                <!-- Existing Git Links -->
                <div class="mb-4">
                    {% if task.gitLinks|length > 0 %}
                        <div class="space-y-2" x-data="{ gitLinks: {{ task.gitLinks|json_encode }} }">
                            <template x-for="gitLink in gitLinks" :key="gitLink.id">
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                    <div class="flex items-center space-x-3">
                                        <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                        </svg>
                                        <div>
                                            <div x-show="gitLink.commitHash">
                                                <p class="text-sm font-medium text-gray-900">
                                                    Commit: <span class="font-mono text-xs bg-gray-200 px-1 py-0.5 rounded" x-text="gitLink.commitHash ? gitLink.commitHash.substring(0, 8) + '...' : ''"></span>
                                                </p>
                                            </div>
                                            <div x-show="gitLink.prReference">
                                                <p class="text-sm font-medium text-gray-900">
                                                    Pull Request: <span class="text-blue-600" x-text="gitLink.prReference"></span>
                                                </p>
                                            </div>
                                            <p class="text-xs text-gray-500" x-text="new Date(gitLink.createdAt.date).toLocaleDateString()"></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-2">
                                        <button 
                                            @click="removeGitLink(gitLink.id, $event.target)"
                                            class="text-red-600 hover:text-red-500 text-sm"
                                            type="button"
                                        >
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-sm">No git links currently attached</p>
                    {% endif %}
                </div>

                <!-- Add Git Link Form -->
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-4" x-data="gitLinkManager()">
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label for="commit-hash" class="block text-sm font-medium text-gray-700 mb-1">Commit Hash</label>
                                <input 
                                    type="text" 
                                    id="commit-hash"
                                    x-model="newGitLink.commitHash"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                                    placeholder="e.g., a1b2c3d4e5f6"
                                >
                            </div>
                            <div>
                                <label for="pr-reference" class="block text-sm font-medium text-gray-700 mb-1">PR Reference</label>
                                <input 
                                    type="text" 
                                    id="pr-reference"
                                    x-model="newGitLink.prReference"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                                    placeholder="e.g., #123 or PR-123"
                                >
                            </div>
                        </div>
                        <div class="flex justify-end">
                            <button 
                                @click="addGitLink()"
                                x-bind:disabled="!canAddGitLink()"
                                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed rounded-md"
                                type="button"
                            >
                                Add Git Link
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="flex justify-end space-x-3">
                <a 
                    href="{{ path('app_task_detail', {'id': task.id}) }}"
                    class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md"
                >
                    Cancel
                </a>
                <button 
                    type="submit"
                    class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md"
                    hx-on::after-request="if(event.detail.successful) { window.location.href='{{ path('app_task_detail', {'id': task.id}) }}'; }"
                >
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function fileUploadEdit() {
    return {
        newFiles: [],
        uploading: false,

        handleFileSelect(event) {
            const files = Array.from(event.target.files);
            this.newFiles.push(...files);
        },

        removeNewFile(file) {
            const index = this.newFiles.findIndex(f => f === file);
            if (index > -1) {
                this.newFiles.splice(index, 1);
            }
        },

        async uploadFile(file) {
            this.uploading = true;

            try {
                const formData = new FormData();
                formData.append('files[]', file);
                formData.append('task_id', '{{ task.id }}');

                const response = await fetch('/files/upload', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const result = await response.json();

                if (result.success && result.uploaded_files) {
                    // Remove file from newFiles
                    this.removeNewFile(file);
                    
                    // Refresh the page to show the new file
                    window.location.reload();
                } else {
                    this.showNotification('Failed to upload file', 'error');
                }
            } catch (error) {
                console.error('Upload error:', error);
                this.showNotification('An error occurred while uploading', 'error');
            } finally {
                this.uploading = false;
            }
        },

        async removeFile(fileId, target) {
            if (!confirm('Are you sure you want to delete this file?')) {
                return;
            }

            try {
                const response = await fetch(`/files/delete/${fileId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    // Remove the file element from the DOM
                    target.closest('.flex.items-center.justify-between').remove();
                    this.showNotification('File deleted successfully', 'success');
                } else {
                    this.showNotification('Failed to delete file', 'error');
                }
            } catch (error) {
                console.error('Delete error:', error);
                this.showNotification('An error occurred while deleting', 'error');
            }
        },

        showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    };
}

function gitLinkManager() {
    return {
        newGitLink: {
            commitHash: '',
            prReference: ''
        },

        canAddGitLink() {
            return this.newGitLink.commitHash.trim() !== '' || this.newGitLink.prReference.trim() !== '';
        },

        async addGitLink() {
            if (!this.canAddGitLink()) {
                return;
            }

            try {
                const response = await fetch('/api/git-links/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        task_id: {{ task.id }},
                        commit_hash: this.newGitLink.commitHash.trim() || null,
                        pr_reference: this.newGitLink.prReference.trim() || null
                    })
                });

                const result = await response.json();

                if (result.success) {
                    // Reset form
                    this.newGitLink = {
                        commitHash: '',
                        prReference: ''
                    };
                    
                    // Refresh the page to show the new git link
                    window.location.reload();
                    this.showNotification('Git link added successfully', 'success');
                } else {
                    this.showNotification('Failed to add git link', 'error');
                }
            } catch (error) {
                console.error('Add git link error:', error);
                this.showNotification('An error occurred while adding git link', 'error');
            }
        },

        async removeGitLink(gitLinkId, target) {
            if (!confirm('Are you sure you want to delete this git link?')) {
                return;
            }

            try {
                const response = await fetch(`/api/git-links/${gitLinkId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const result = await response.json();

                if (result.success) {
                    // Remove the git link element from the DOM
                    target.closest('.flex.items-center.justify-between').remove();
                    this.showNotification('Git link deleted successfully', 'success');
                } else {
                    this.showNotification('Failed to delete git link', 'error');
                }
            } catch (error) {
                console.error('Delete git link error:', error);
                this.showNotification('An error occurred while deleting git link', 'error');
            }
        },

        showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    };
}
</script>
{% endblock %}