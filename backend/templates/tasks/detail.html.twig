{% extends 'base.html.twig' %}

{% block title %}{{ task.title }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <!-- Task Header -->
        <div class="flex items-start justify-between mb-6">
            <div class="flex-1">
                <div class="flex items-center mb-2">
                    <a href="{{ path('app_project_detail', {'id': task.project.id}) }}" class="text-gray-500 hover:text-gray-700 mr-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </a>
                    <h1 class="text-2xl font-bold text-gray-900">{{ task.title }}</h1>
                    <span class="ml-3 px-3 py-1 text-sm font-medium rounded-full {{ task.priorityColor }}">
                        {{ task.priorityLabel }} Priority
                    </span>
                </div>
                
                <div class="flex items-center space-x-4 text-sm text-gray-500">
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                        Project: <a href="{{ path('app_project_detail', {'id': task.project.id}) }}" class="ml-1 text-blue-600 hover:underline">{{ task.project.title }}</a>
                    </div>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        Created: {{ task.createdAt|date('M j, Y g:i A') }}
                    </div>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Updated: {{ task.updatedAt|date('M j, Y g:i A') }}
                    </div>
                </div>
            </div>
            
            <div class="flex items-center space-x-2 ml-4">
                <button 
                    class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                    x-data
                    @click="window.location.href='{{ path('app_task_edit', {'id': task.id}) }}'"
                >
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Edit
                </button>
                <button 
                    class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700"
                    hx-delete="/tasks/{{ task.id }}/delete"
                    hx-confirm="Are you sure you want to delete this task?"
                    hx-redirect="{{ path('app_project_detail', {'id': task.project.id}) }}"
                >
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete
                </button>
            </div>
        </div>

        <!-- Status Badge -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                {% if task.status == 'completed' or task.status == 'done' %}
                    bg-green-100 text-green-800
                {% elseif task.status == 'in_progress' or task.status == 'working' %}
                    bg-blue-100 text-blue-800
                {% elseif task.status == 'review' %}
                    bg-purple-100 text-purple-800
                {% else %}
                    bg-gray-100 text-gray-800
                {% endif %}
            ">
                {{ task.status|replace({'_': ' '})|title }}
            </span>
        </div>

        <!-- Description -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
            <div class="prose max-w-none">
                {% if task.description %}
                    <p class="text-gray-600">{{ task.description|nl2br }}</p>
                {% else %}
                    <p class="text-gray-400 italic">No description provided</p>
                {% endif %}
            </div>
        </div>

        <!-- Files Section -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Attached Files</label>
            <div class="border border-gray-200 rounded-lg p-4">
                {% if task.files|length > 0 %}
                    <div class="space-y-2">
                        {% for file in task.files %}
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                                    </svg>
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">{{ file.filename }}</p>
                                        <p class="text-xs text-gray-500">{{ file.createdAt|date('M j, Y g:i A') }}</p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-2">
                                    <a 
                                        href="{{ path('app_file_download', {'id': file.id}) }}"
                                        class="text-blue-600 hover:text-blue-500 text-sm"
                                        download
                                    >
                                        Download
                                    </a>
                                    <button 
                                        hx-delete="{{ path('app_file_delete', {'id': file.id}) }}"
                                        hx-confirm="Are you sure you want to delete this file?"
                                        hx-target="closest div"
                                        hx-swap="outerHTML"
                                        class="text-red-600 hover:text-red-500 text-sm"
                                    >
                                        Delete
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-gray-500 text-sm">No files attached</p>
                {% endif %}
            </div>
        </div>

        <!-- Git Links Section -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Git Links</label>
            <div class="border border-gray-200 rounded-lg p-4">
                {% if task.gitLinks|length > 0 %}
                    <div class="space-y-2">
                        {% for gitLink in task.gitLinks %}
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                <div class="flex items-center space-x-3">
                                    <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                    </svg>
                                    <div>
                                        {% if gitLink.commitHash %}
                                            <p class="text-sm font-medium text-gray-900">
                                                Commit: <span class="font-mono text-xs bg-gray-200 px-1 py-0.5 rounded">{{ gitLink.commitHash|slice(0, 8) }}...</span>
                                            </p>
                                        {% endif %}
                                        {% if gitLink.prReference %}
                                            <p class="text-sm font-medium text-gray-900">
                                                Pull Request: <span class="text-blue-600">{{ gitLink.prReference }}</span>
                                            </p>
                                        {% endif %}
                                        <p class="text-xs text-gray-500">{{ gitLink.createdAt|date('M j, Y g:i A') }}</p>
                                    </div>
                                </div>
                                {% if gitLink.commitHash %}
                                    {% if task.project.githubRepo %}
                                        <div class="flex items-center space-x-2">
                                            <a 
                                                href="https://github.com/{{ task.project.githubRepo }}/commit/{{ gitLink.commitHash }}"
                                                target="_blank"
                                                class="text-blue-600 hover:text-blue-500 text-sm"
                                            >
                                                View Commit
                                            </a>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-gray-500 text-sm">No commits or pull requests linked</p>
                {% endif %}
            </div>
        </div>

        <!-- AI Summary Section -->
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">AI Summary</label>
            <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
                <p class="text-gray-500 text-sm italic">AI summaries will be available in a future update</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}