                                </template>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Modal Footer -->
            <div class="px-6 py-4 border-t border-gray-200 flex justify-end space-x-3">
                <button 
                    @click="closeModal()"
                    class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md"
                    type="button"
                >
                    Cancel
                </button>
                <button 
                    @click="submitTask()"
                    x-bind:disabled="isSubmitting"
                    class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed rounded-md"
                    type="button"
                >
                    <span x-show="!isSubmitting">Create Task</span>
                    <span x-show="isSubmitting" class="flex items-center">
                        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Creating...
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function kanbanBoard() {
    return {
        draggedTask: null,
        draggedFromStatus: null,
        backlogTasks: [
            { 
                id: 1, 
                title: 'Design user interface', 
                description: 'Create mockups for the new feature', 
                project: 'Project Alpha',
                priority_color: 'text-orange-600 bg-orange-100',
                priority_label: 'High'
            },
            { 
                id: 2, 
                title: 'Database schema', 
                description: 'Design the database structure', 
                project: 'Project Beta',
                priority_color: 'text-yellow-600 bg-yellow-100',
                priority_label: 'Medium'
            }
        ],
        todoTasks: [
            { 
                id: 3, 
                title: 'API integration', 
                description: 'Connect frontend with backend API', 
                project: 'Project Alpha',
                priority_color: 'text-red-600 bg-red-100',
                priority_label: 'Critical'
            }
        ],
        workingTasks: [
            { 
                id: 4, 
                title: 'Authentication system', 
                description: 'Implement user login and registration', 
                project: 'Project Gamma',
                priority_color: 'text-orange-600 bg-orange-100',
                priority_label: 'High'
            }
        ],
        reviewTasks: [
            { 
                id: 5, 
                title: 'Code review', 
                description: 'Review pull request #123', 
                project: 'Project Alpha',
                priority_color: 'text-yellow-600 bg-yellow-100',
                priority_label: 'Medium'
            }
        ],
        doneTasks: [
            { 
                id: 6, 
                title: 'Setup development environment', 
                description: 'Configure Docker containers', 
                project: 'Project Setup',
                priority_color: 'text-green-600 bg-green-100',
                priority_label: 'Low'
            }
        ],
        
        handleDragStart(task, event) {
            this.draggedTask = task;
            // Determine which status the task is being dragged from
            if (this.backlogTasks.includes(task)) this.draggedFromStatus = 'backlog';
            else if (this.todoTasks.includes(task)) this.draggedFromStatus = 'todo';
            else if (this.workingTasks.includes(task)) this.draggedFromStatus = 'in_progress';
            else if (this.reviewTasks.includes(task)) this.draggedFromStatus = 'review';
            else if (this.doneTasks.includes(task)) this.draggedFromStatus = 'completed';
            
            event.target.classList.add('opacity-50');
            event.dataTransfer.effectAllowed = 'move';
        },
        
        handleDragEnd(event) {
            event.target.classList.remove('opacity-50');
        },
        
        async handleDrop(newStatus, event) {
            event.preventDefault();
            
            if (!this.draggedTask || this.draggedFromStatus === newStatus) {
                return;
            }
            
            try {
                // Send HTMX request to update task status
                const response = await fetch(`/api/tasks/${this.draggedTask.id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ status: newStatus })
                });
                
                if (response.ok) {
                    // Move task between arrays
                    this.removeTaskFromCurrentStatus(this.draggedTask);
                    this.addTaskToNewStatus(this.draggedTask, newStatus);
                    
                    // Show success feedback
                    this.showNotification('Task moved successfully!', 'success');
                } else {
                    // Show error feedback
                    this.showNotification('Failed to move task. Please try again.', 'error');
                }
            } catch (error) {
                console.error('Error updating task:', error);
                this.showNotification('Failed to move task. Please try again.', 'error');
            }
            
            this.draggedTask = null;
            this.draggedFromStatus = null;
        },
        
        removeTaskFromCurrentStatus(task) {
            const arrays = {
                'backlog': this.backlogTasks,
                'todo': this.todoTasks,
                'in_progress': this.workingTasks,
                'review': this.reviewTasks,
                'completed': this.doneTasks
            };
            
            const currentArray = arrays[this.draggedFromStatus];
            const index = currentArray.findIndex(t => t.id === task.id);
            if (index > -1) {
                currentArray.splice(index, 1);
            }
        },
        
        addTaskToNewStatus(task, newStatus) {
            const arrays = {
                'backlog': this.backlogTasks,
                'todo': this.todoTasks,
                'in_progress': this.workingTasks,
                'review': this.reviewTasks,
                'completed': this.doneTasks
            };
            
            arrays[newStatus].push(task);
        },
        
        showNotification(message, type) {
            // Simple notification - could be enhanced with a proper notification system
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    }
}

function taskModal() {
    return {
        isOpen: false,
        isSubmitting: false,
        status: 'todo',
        projects: [],
        form: {
            title: '',
            description: '',
            project_id: '',
            priority: 'medium',
            status: 'todo'
        },
        files: [],
        isDragging: false,

        init() {
            this.loadProjects();
        },

        async loadProjects() {
            try {
                const response = await fetch('/api/projects');
                const data = await response.json();
                this.projects = data.data || [];
            } catch (error) {
                console.error('Error loading projects:', error);
            }
        },

        openModal(detail) {
            this.status = detail?.status || 'todo';
            this.form.status = this.status;
            this.isOpen = true;
            this.resetForm();
            
            // Focus on title input after modal is rendered
            this.$nextTick(() => {
                document.getElementById('task-title')?.focus();
            });
        },

        closeModal() {
            this.isOpen = false;
            this.resetForm();
        },

        resetForm() {
            this.form = {
                title: '',
                description: '',
                project_id: '',
                priority: 'medium',
                status: this.status
            };
            this.files = [];
            this.isSubmitting = false;
        },

        handleDrop(event) {
            this.isDragging = false;
            const files = Array.from(event.dataTransfer.files);
            this.addFiles(files);
        },

        handleFileSelect(event) {
            const files = Array.from(event.target.files);
            this.addFiles(files);
        },

        addFiles(files) {
            // Add to files array for preview
            this.files.push(...files);
        },

        removeFile(file) {
            const index = this.files.findIndex(f => f === file);
            if (index > -1) {
                this.files.splice(index, 1);
            }
        },

        async submitTask() {
            if (this.isSubmitting) return;
            
            this.isSubmitting = true;
            
            try {
                const formData = new FormData();
                formData.append('title', this.form.title);
                formData.append('description', this.form.description);
                formData.append('project_id', this.form.project_id);
                formData.append('priority', this.form.priority);
                formData.append('status', this.form.status);
                
                // Add files
                this.files.forEach((file, index) => {
                    formData.append(`files[]`, file);
                });

                const response = await fetch('/tasks/create', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    const taskHtml = await response.text();
                    
                    // Add the new task to the appropriate column
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(taskHtml, 'text/html');
                    const taskElement = doc.body.firstChild;
                    
                    if (taskElement) {
                        // Parse task data from the HTML
                        const taskData = this.parseTaskFromHtml(taskElement);
                        
                        // Add to the appropriate array in kanban board
                        this.addTaskToBoard(taskData);
                        
                        this.showNotification('Task created successfully!', 'success');
                        this.closeModal();
                    }
                } else {
                    const errorData = await response.json();
                    this.showNotification(errorData.message || 'Failed to create task', 'error');
                }
            } catch (error) {
                console.error('Error creating task:', error);
                this.showNotification('An error occurred while creating the task', 'error');
            } finally {
                this.isSubmitting = false;
            }
        },

        parseTaskFromHtml(element) {
            // Extract task data from the rendered HTML
            // This is a simplified approach - in a real app you'd get JSON response
            return {
                id: Math.floor(Math.random() * 10000), // Temporary ID
                title: this.form.title,
                description: this.form.description,
                project: this.projects.find(p => p.id == this.form.project_id)?.name || 'Unknown',
                priority_color: this.getPriorityColor(this.form.priority),
                priority_label: this.getPriorityLabel(this.form.priority)
            };
        },

        addTaskToBoard(taskData) {
            // Get the kanban board component and add task to appropriate array
            const kanbanComponent = Alpine.findClosest(document.body, '[x-data*="kanbanBoard"]');
            if (kanbanComponent) {
                const data = kanbanComponent._x_dataStack[0];
                switch (this.status) {
                    case 'backlog':
                        data.backlogTasks.push(taskData);
                        break;
                    case 'todo':
                        data.todoTasks.push(taskData);
                        break;
                    case 'in_progress':
                        data.workingTasks.push(taskData);
                        break;
                    case 'review':
                        data.reviewTasks.push(taskData);
                        break;
                    case 'completed':
                        data.doneTasks.push(taskData);
                        break;
                }
            }
        },

        getPriorityColor(priority) {
            const colors = {
                low: 'text-green-600 bg-green-100',
                medium: 'text-yellow-600 bg-yellow-100',
                high: 'text-orange-600 bg-orange-100',
                critical: 'text-red-600 bg-red-100'
            };
            return colors[priority] || colors.medium;
        },

        getPriorityLabel(priority) {
            const labels = {
                low: 'Low',
                medium: 'Medium', 
                high: 'High',
                critical: 'Critical'
            };
            return labels[priority] || 'Medium';
        },

        showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    };
}

// Simple file upload component for the modal
function fileUpload() {
    return {
        files: [],
        isDragging: false,
        uploading: false,

        handleDrop(event) {
            this.isDragging = false;
            const files = Array.from(event.dataTransfer.files);
            this.files.push(...files);
        },

        handleFileSelect(event) {
            const files = Array.from(event.target.files);
            this.files.push(...files);
        },

        removeFile(file) {
            const index = this.files.findIndex(f => f === file);
            if (index > -1) {
                this.files.splice(index, 1);
            }
        }
    };
}

// Board search functionality
function boardSearch() {
    return {
        searchQuery: '',
        originalTasks: null,

        init() {
            // Store original task data for filtering
            this.originalTasks = {
                backlog: [...this.getAllTasks('backlog')],
                todo: [...this.getAllTasks('todo')],
                in_progress: [...this.getAllTasks('in_progress')],
                review: [...this.getAllTasks('review')],
                completed: [...this.getAllTasks('completed')]
            };
        },

        filterTasks() {
            const kanbanComponent = this.getKanbanComponent();
            if (!kanbanComponent || !this.originalTasks) return;

            const query = this.searchQuery.toLowerCase().trim();
            
            if (!query) {
                // Restore all tasks
                kanbanComponent.backlogTasks = [...this.originalTasks.backlog];
                kanbanComponent.todoTasks = [...this.originalTasks.todo];
                kanbanComponent.workingTasks = [...this.originalTasks.in_progress];
                kanbanComponent.reviewTasks = [...this.originalTasks.review];
                kanbanComponent.doneTasks = [...this.originalTasks.completed];
                return;
            }

            // Filter tasks based on search query
            kanbanComponent.backlogTasks = this.originalTasks.backlog.filter(task => 
                this.taskMatchesQuery(task, query)
            );
            kanbanComponent.todoTasks = this.originalTasks.todo.filter(task => 
                this.taskMatchesQuery(task, query)
            );
            kanbanComponent.workingTasks = this.originalTasks.in_progress.filter(task => 
                this.taskMatchesQuery(task, query)
            );
            kanbanComponent.reviewTasks = this.originalTasks.review.filter(task => 
                this.taskMatchesQuery(task, query)
            );
            kanbanComponent.doneTasks = this.originalTasks.completed.filter(task => 
                this.taskMatchesQuery(task, query)
            );
        },

        taskMatchesQuery(task, query) {
            return task.title.toLowerCase().includes(query) ||
                   task.description.toLowerCase().includes(query) ||
                   task.project.toLowerCase().includes(query);
        },

        getAllTasks(status) {
            const kanbanComponent = this.getKanbanComponent();
            if (!kanbanComponent) return [];

            switch (status) {
                case 'backlog': return kanbanComponent.backlogTasks;
                case 'todo': return kanbanComponent.todoTasks;
                case 'in_progress': return kanbanComponent.workingTasks;
                case 'review': return kanbanComponent.reviewTasks;
                case 'completed': return kanbanComponent.doneTasks;
                default: return [];
            }
        },

        getKanbanComponent() {
            const kanbanElement = document.querySelector('[x-data*="kanbanBoard"]');
            return kanbanElement ? kanbanElement._x_dataStack[0] : null;
        }
    };
}

// Project filter functionality
function projectFilter() {
    return {
        selectedProject: '',
        originalTasks: null,

        init() {
            // Load projects dynamically
            this.loadProjects();
            
            // Store original task data
            this.originalTasks = {
                backlog: [...this.getAllTasks('backlog')],
                todo: [...this.getAllTasks('todo')],
                in_progress: [...this.getAllTasks('in_progress')],
                review: [...this.getAllTasks('review')],
                completed: [...this.getAllTasks('completed')]
            };
        },

        async loadProjects() {
            try {
                const response = await fetch('/api/projects');
                const data = await response.json();
                
                // Update the select options dynamically
                const selectElement = this.$el;
                selectElement.innerHTML = '<option value="">All Projects</option>';
                
                if (data.data) {
                    data.data.forEach(project => {
                        const option = document.createElement('option');
                        option.value = project.id;
                        option.textContent = project.title;
                        selectElement.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error loading projects:', error);
            }
        },

        filterByProject() {
            const kanbanComponent = this.getKanbanComponent();
            if (!kanbanComponent || !this.originalTasks) return;

            if (!this.selectedProject) {
                // Show all tasks
                kanbanComponent.backlogTasks = [...this.originalTasks.backlog];
                kanbanComponent.todoTasks = [...this.originalTasks.todo];
                kanbanComponent.workingTasks = [...this.originalTasks.in_progress];
                kanbanComponent.reviewTasks = [...this.originalTasks.review];
                kanbanComponent.doneTasks = [...this.originalTasks.completed];
                return;
            }

            // Filter tasks by selected project
            kanbanComponent.backlogTasks = this.originalTasks.backlog.filter(task => 
                task.project_id == this.selectedProject
            );
            kanbanComponent.todoTasks = this.originalTasks.todo.filter(task => 
                task.project_id == this.selectedProject
            );
            kanbanComponent.workingTasks = this.originalTasks.in_progress.filter(task => 
                task.project_id == this.selectedProject
            );
            kanbanComponent.reviewTasks = this.originalTasks.review.filter(task => 
                task.project_id == this.selectedProject
            );
            kanbanComponent.doneTasks = this.originalTasks.completed.filter(task => 
                task.project_id == this.selectedProject
            );
        },

        getAllTasks(status) {
            const kanbanComponent = this.getKanbanComponent();
            if (!kanbanComponent) return [];

            switch (status) {
                case 'backlog': return kanbanComponent.backlogTasks;
                case 'todo': return kanbanComponent.todoTasks;
                case 'in_progress': return kanbanComponent.workingTasks;
                case 'review': return kanbanComponent.reviewTasks;
                case 'completed': return kanbanComponent.doneTasks;
                default: return [];
            }
        },

        getKanbanComponent() {
            const kanbanElement = document.querySelector('[x-data*="kanbanBoard"]');
            return kanbanElement ? kanbanElement._x_dataStack[0] : null;
        }
    };
}
