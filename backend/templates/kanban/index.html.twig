{% extends 'base.html.twig' %}

{% block title %}Kanban Board - {{ parent() }}{% endblock %}

{% block body %}
<div class="max-w-full px-4 sm:px-6 lg:px-8 py-8">
    <!-- Enhanced Header -->
    <div class="mb-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between space-y-4 lg:space-y-0">
            <div class="space-y-2">
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Kanban Board</h1>
                <p class="text-gray-600 dark:text-gray-400">Manage your tasks across different stages</p>
                <div class="flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400">
                    <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        <span id="task-count">{{ tasksByStatus|reduce((carry, tasks) => carry + tasks|length, 0) }} tasks</span>
                    </span>
                    <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Last updated: <span id="last-updated">{{ 'now'|date('g:i A') }}</span>
                    </span>
                </div>
            </div>
            
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center space-y-3 sm:space-y-0 sm:space-x-4">
                <!-- Enhanced Quick Search -->
                <div class="relative" x-data="{ query: '', focused: false }">
                    <input 
                        type="text" 
                        x-model="query"
                        @focus="focused = true"
                        @blur="setTimeout(() => focused = false, 200)"
                        data-search-input
                        placeholder="Search tasks... (⌘K)"
                        class="w-64 pl-10 pr-4 py-2.5 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200"
                    >
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                </div>
                
                <!-- Enhanced Project Filter -->
                <div class="relative" x-data="{ open: false }">
                    <button @click="open = !open"
                            class="flex items-center px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-all duration-200">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                        </svg>
                        <span id="selected-project-name">{{ selectedProject ? projects|filter(p => p.id == selectedProject)|first.title|default('All Projects') : 'All Projects' }}</span>
                        <svg class="w-4 h-4 ml-2 transition-transform duration-200" :class="{ 'rotate-180': open }" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                    </button>
                    <div x-show="open" 
                         @click.away="open = false"
                         x-transition
                         class="absolute top-full left-0 mt-1 w-56 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl z-50 py-1">
                        <a href="{{ path('app_kanban') }}" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
                            All Projects
                        </a>
                        {% for project in projects %}
                        <a href="{{ path('app_kanban', {'project': project.id}) }}" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                            <span class="w-3 h-3 bg-{{ cycle(['green', 'purple', 'yellow', 'red'], loop.index0) }}-500 rounded-full mr-3"></span>
                            {{ project.title }}
                        </a>
                        {% endfor %}
                    </div>
                </div>
                
                <!-- View Options -->
                <div class="flex rounded-lg border border-gray-300 dark:border-gray-600 overflow-hidden">
                    <button class="px-3 py-2 bg-primary-500 text-white text-sm font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2a2 2 0 002-2z"/>
                        </svg>
                    </button>
                    <button class="px-3 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 text-sm font-medium border-l border-gray-300 dark:border-gray-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="flex space-x-6 overflow-x-auto pb-6" x-data="kanbanBoard()">
        {% for status, statusInfo in statuses %}
        <div class="kanban-column flex-shrink-0 {% if status == 'in_progress' %}bg-blue-50 border-blue-200{% endif %} flex flex-col" 
             :class="collapsed_{{ status|replace({'_': ''}) }} ? 'w-16' : 'w-80'"
             data-status="{{ status }}"
             :style="{
                 'background': draggedTask && draggedFromStatus !== '{{ status }}' ? 'linear-gradient(135deg, rgb(239 246 255), rgb(219 234 254))' : '',
                 'border': draggedTask && draggedFromStatus !== '{{ status }}' ? '2px dashed rgb(147 197 253)' : 
                          draggedTask && draggedFromStatus === '{{ status }}' ? '2px dashed rgb(252 165 165)' : '',
                 'border-radius': draggedTask ? '8px' : ''
             }"
             @dragover.prevent="handleDragOver('{{ status }}', $event)"
             @dragenter.prevent="handleDragEnter('{{ status }}', $event)"
             @dragleave.prevent="handleDragLeave('{{ status }}', $event)"
             @drop.prevent="handleDrop('{{ status }}', $event)">
            <div class="flex items-center justify-between mb-4 flex-shrink-0">
                <h2 class="text-lg font-semibold {% if status == 'in_progress' %}text-blue-800{% else %}text-gray-800{% endif %}" x-show="!collapsed_{{ status|replace({'_': ''}) }}">{{ statusInfo.label }}</h2>
                <h2 class="text-sm font-semibold {% if status == 'in_progress' %}text-blue-800{% else %}text-gray-800{% endif %} transform -rotate-90 whitespace-nowrap" x-show="collapsed_{{ status|replace({'_': ''}) }}">{{ statusInfo.label }}</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-{{ statusInfo.color }}-200 text-{{ statusInfo.color }}-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed_{{ status|replace({'_': ''}) }}">{{ tasksByStatus[status]|length }}</span>
                    <button @click="collapsed_{{ status|replace({'_': ''}) }} = !collapsed_{{ status|replace({'_': ''}) }}" class="text-{{ statusInfo.color }}-500 hover:text-{{ statusInfo.color }}-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed_{{ status|replace({'_': ''}) }} ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 flex-1 min-h-32 transition-all duration-300 ease-in-out relative" 
                 x-ref="{{ status }}Column" 
                 x-show="!collapsed_{{ status|replace({'_': ''}) }}" 
                 x-transition>
                <!-- Drop placeholder - shows when dragging from other columns -->
                <div x-show="draggedTask && draggedFromStatus !== '{{ status }}'" 
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute inset-0 flex items-center justify-center border-2 border-dashed border-blue-400 dark:border-blue-500 bg-blue-50/50 dark:bg-blue-900/20 rounded-lg backdrop-blur-sm">
                    <div class="flex items-center text-blue-600 dark:text-blue-400">
                        <svg class="w-5 h-5 mr-2 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                        <span class="text-sm font-semibold">Drop task here</span>
                    </div>
                </div>

                <!-- Task cards -->
                {% for task in tasksByStatus[status] %}
                <div class="kanban-card {% if status == 'in_progress' %}border-blue-200{% endif %} transition-all duration-300" 
                     data-task-id="{{ task.id }}"
                     draggable="true"
                     x-show="true"
                     :style="{
                         'opacity': draggedTask && draggedTask.id !== {{ task.id }} && draggedFromStatus !== '{{ status }}' ? '0.3' : 
                                   draggedTask && draggedTask.id !== {{ task.id }} && draggedFromStatus === '{{ status }}' ? '0.1' : '1',
                         'transform': draggedTask && draggedTask.id !== {{ task.id }} ? 'scale(0.95)' : 'scale(1)',
                         'pointer-events': draggedTask && draggedTask.id !== {{ task.id }} && draggedFromStatus !== '{{ status }}' ? 'none' : 'auto'
                     }"
                     :class="{
                         'shadow-lg ring-2 ring-primary-300 dark:ring-primary-600': draggedTask && draggedTask.id === {{ task.id }},
                         'bg-primary-50 dark:bg-primary-900/10': draggedTask && draggedTask.id === {{ task.id }}
                     }"
                     @dragstart="handleDragStart({{ task|json_encode }}, $event)"
                     @dragend="handleDragEnd($event)">
                    <div class="flex items-start justify-between mb-2">
                        <h3 class="font-medium text-gray-900 flex-1">{{ task.title }}</h3>
                        <span class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2 
                            {% if task.priority == 'low' %}text-green-600 bg-green-100
                            {% elseif task.priority == 'medium' %}text-yellow-600 bg-yellow-100
                            {% elseif task.priority == 'high' %}text-orange-600 bg-orange-100
                            {% elseif task.priority == 'critical' %}text-red-600 bg-red-100
                            {% else %}text-gray-600 bg-gray-100{% endif %}">
                            {{ task.priority|capitalize }}
                        </span>
                    </div>
                    <p class="text-sm text-gray-600 mt-1">{{ task.description }}</p>
                    <div class="flex items-center justify-between mt-3">
                        <span class="text-xs text-gray-500">{{ task.project.name|default('No Project') }}</span>
                        <div class="flex space-x-1">
                            <button @click="$dispatch('open-edit-modal', { task: {{ task|json_encode }} })" class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                            <button @click="deleteTask({{ task.id }})" class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <!-- Add Task Button - Fixed at bottom of column -->
            <button class="w-full mt-4 p-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-500 hover:border-gray-400 hover:text-gray-600 flex-shrink-0" 
                    x-show="!collapsed_{{ status|replace({'_': ''}) }}" 
                    x-transition 
                    @click="$dispatch('open-task-modal', { status: '{{ status }}' })">
                + Add Task
            </button>
        </div>
        {% endfor %}
    </div>
</div>

<!-- Task Creation Modal -->
<div x-data="taskModal()" 
     x-show="isOpen" 
     @open-task-modal.window="open($event.detail.status)"
     x-cloak
     class="fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4">
        <div x-show="isOpen" @click="close()" class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
        
        <div x-show="isOpen" 
             x-transition:enter="ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
             x-transition:leave="ease-in duration-200"
             x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
             x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
             class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl transform transition-all sm:max-w-lg sm:w-full">
            
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Create New Task</h2>
                    <button @click="close()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>
            
            <form @submit.prevent="submitTask()" class="px-6 py-4">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
                        <input type="text" x-model="form.title" required
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                        <textarea x-model="form.description" rows="3"
                                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500"></textarea>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Project</label>
                        <select x-model="form.project_id"
                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                            <option value="">Select a project...</option>
                            {% for project in projects %}
                            <option value="{{ project.id }}">{{ project.title }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Priority</label>
                        <select x-model="form.priority"
                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                </div>
                
                <div class="flex justify-end space-x-3 mt-6">
                    <button type="button" @click="close()"
                            class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                        Cancel
                    </button>
                    <button type="submit"
                            class="px-4 py-2 bg-primary-500 text-white rounded-md hover:bg-primary-600">
                        Create Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Task Edit Modal -->
<div x-data="editTaskModal()" 
     x-show="isOpen" 
     @open-edit-modal.window="open($event.detail.task)"
     x-cloak
     class="fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4">
        <div x-show="isOpen" @click="close()" class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
        
        <div x-show="isOpen" 
             x-transition:enter="ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
             x-transition:leave="ease-in duration-200"
             x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
             x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
             class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl transform transition-all sm:max-w-lg sm:w-full">
            
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Edit Task</h2>
                    <button @click="close()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>
            
            <form @submit.prevent="updateTask()" class="px-6 py-4">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
                        <input type="text" x-model="form.title" required
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                        <textarea x-model="form.description" rows="3"
                                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500"></textarea>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Priority</label>
                        <select x-model="form.priority"
                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                            <option value="low">Low</option>
                            <option value="medium">Medium</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Status</label>
                        <select x-model="form.status"
                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
                            {% for status, statusInfo in statuses %}
                            <option value="{{ status }}">{{ statusInfo.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                
                <div class="flex justify-end space-x-3 mt-6">
                    <button type="button" @click="close()"
                            class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                        Cancel
                    </button>
                    <button type="submit"
                            class="px-4 py-2 bg-primary-500 text-white rounded-md hover:bg-primary-600">
                        Update Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function kanbanBoard() {
    return {
        draggedTask: null,
        draggedFromStatus: null,
        tasks: {{ tasksByStatus|json_encode|raw }},
        // Collapsed states for each column
        {% for status in statuses|keys %}
        collapsed_{{ status|replace({'_': ''}) }}: false,
        {% endfor %}
        
        handleDragStart(task, event) {
            this.draggedTask = task;
            // Find which status the task is from
            for (const [status, tasks] of Object.entries(this.tasks)) {
                if (tasks.some(t => t.id === task.id)) {
                    this.draggedFromStatus = status;
                    break;
                }
            }
            
            event.dataTransfer.setData('text/plain', task.id.toString());
            
            // Add global dragging state to body
            document.body.classList.add('dragging');
            
            // Set initial drop states on all columns
            this.updateDropStates();
            
            // Create an enhanced drag preview
            this.createDragPreview(task, event);
        },

        handleDragEnd(event) {
            // Remove global dragging state
            document.body.classList.remove('dragging');
            
            // Clear drop states on all columns
            document.querySelectorAll('.kanban-column').forEach(column => {
                column.removeAttribute('data-can-drop');
            });
            
            // Don't immediately clear - let handleDrop run first
            setTimeout(() => {
                this.draggedTask = null;
                this.draggedFromStatus = null;
            }, 100);
        },

        handleDragOver(status, event) {
            event.preventDefault();
            event.stopPropagation();
            
            if (this.draggedTask && this.draggedFromStatus !== status) {
                event.dataTransfer.dropEffect = 'move';
            } else {
                event.dataTransfer.dropEffect = 'none';
            }
        },

        handleDragEnter(status, event) {
            event.preventDefault();
            event.stopPropagation();
            
            if (this.draggedTask && this.draggedFromStatus !== status) {
                event.dataTransfer.dropEffect = 'move';
            } else {
                event.dataTransfer.dropEffect = 'none';
            }
        },

        handleDragLeave(status, event) {
            event.preventDefault();
            event.stopPropagation();
        },

        updateDropStates() {
            if (!this.draggedTask || !this.draggedFromStatus) return;
            
            // Update data attributes on all columns to control visual feedback
            document.querySelectorAll('.kanban-column').forEach(column => {
                const status = column.getAttribute('data-status');
                if (status === this.draggedFromStatus) {
                    column.setAttribute('data-can-drop', 'false');
                } else {
                    column.setAttribute('data-can-drop', 'true');
                }
            });
        },

        createDragPreview(task, event) {
            const dragPreview = document.createElement('div');
            dragPreview.className = 'drag-preview';

            const titleEl = document.createElement('div');
            titleEl.style.cssText = 'font-weight:600;color:#1f2937;margin-bottom:4px;';
            titleEl.textContent = `📋 ${task.title || ''}`;
            dragPreview.appendChild(titleEl);

            const noteEl = document.createElement('div');
            noteEl.style.cssText = 'font-size:12px;color:#6b7280;';
            noteEl.textContent = 'Moving to new column...';
            dragPreview.appendChild(noteEl);

            const metaRow = document.createElement('div');
            metaRow.style.cssText = 'display:flex;align-items:center;justify-content:space-between;margin-top:8px;';
            const projEl = document.createElement('span');
            projEl.style.cssText = 'font-size:11px;color:#9ca3af;';
            projEl.textContent = (task.project && task.project.name) ? task.project.name : 'No Project';
            const prioEl = document.createElement('span');
            prioEl.style.cssText = 'background:#fbbf24;color:white;padding:2px 6px;border-radius:12px;font-size:10px;';
            prioEl.textContent = task.priority || '';
            metaRow.append(projEl, prioEl);
            dragPreview.appendChild(metaRow);

            // Position off-screen
            dragPreview.style.position = 'absolute';
            dragPreview.style.top = '-1000px';
            dragPreview.style.left = '-1000px';
            dragPreview.style.pointerEvents = 'none';
            dragPreview.style.zIndex = '9999';

            document.body.appendChild(dragPreview);

            // Set the custom drag image
            event.dataTransfer.setDragImage(dragPreview, 140, 40);

            // Clean up the preview element
            setTimeout(() => {
                if (document.body.contains(dragPreview)) {
                    document.body.removeChild(dragPreview);
                }
            }, 0);
        },
        
        async handleDrop(newStatus, event) {
            event.preventDefault();
            
            // Clean up dragging state immediately
            document.body.classList.remove('dragging');
            document.querySelectorAll('.kanban-column').forEach(column => {
                column.removeAttribute('data-can-drop');
            });
            
            // Store references before they potentially get cleared
            const draggedTask = this.draggedTask;
            const draggedFromStatus = this.draggedFromStatus;
            
            if (!draggedTask || draggedFromStatus === newStatus) {
                console.log('Invalid drop:', { draggedTask, draggedFromStatus, newStatus });
                return;
            }
            
            console.log('Processing drop:', { taskId: draggedTask.id, from: draggedFromStatus, to: newStatus });
            
            try {
                // Get CSRF token
                const csrfResponse = await fetch('/api/csrf-token');
                const csrfData = await csrfResponse.json();
                
                const response = await fetch('/api/kanban/move-task', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-Token': csrfData.csrf_token
                    },
                    body: JSON.stringify({
                        taskId: draggedTask.id,
                        status: newStatus
                    })
                });
                
                if (!response.ok) {
                    throw new Error('Failed to move task');
                }
                
                // Move task in UI data
                const fromTasks = this.tasks[draggedFromStatus];
                const taskIndex = fromTasks.findIndex(t => t.id === draggedTask.id);
                if (taskIndex > -1) {
                    fromTasks.splice(taskIndex, 1);
                }
                
                // Update task status and add to new status
                draggedTask.status = newStatus;
                this.tasks[newStatus].push(draggedTask);
                
                // Move DOM element to the tasks container within the target column
                const taskElement = document.querySelector(`[data-task-id="${draggedTask.id}"]`);
                const targetColumn = document.querySelector(`[data-status="${newStatus}"] > div[x-ref="${newStatus}Column"]`);
                
                if (taskElement && targetColumn) {
                    taskElement.classList.remove('opacity-50');
                    targetColumn.appendChild(taskElement);
                }
                
                // Update UI
                this.updateTaskCounts();
                this.updateColumnCounts();
                this.showNotification('Task moved successfully', 'success');
                
                // Clear drag state immediately after successful drop
                this.draggedTask = null;
                this.draggedFromStatus = null;
                
            } catch (error) {
                console.error('Error moving task:', error);
                this.showNotification('Failed to move task. Please try again.', 'error');
                
                // Clear drag state even on error
                this.draggedTask = null;
                this.draggedFromStatus = null;
            }
        },
        
        updateTaskCounts() {
            const totalTasks = Object.values(this.tasks).reduce((sum, tasks) => sum + tasks.length, 0);
            document.getElementById('task-count').textContent = `${totalTasks} tasks`;
            document.getElementById('last-updated').textContent = new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
        },
        
        updateColumnCounts() {
            // Update the count badges for each column
            for (const [status, tasks] of Object.entries(this.tasks)) {
                const columnElement = document.querySelector(`[data-status="${status}"]`);
                if (columnElement) {
                    const countBadge = columnElement.parentElement.querySelector('.bg-gray-200, .bg-blue-200, .bg-green-200, .bg-yellow-200, .bg-red-200');
                    if (countBadge) {
                        countBadge.textContent = tasks.length;
                    }
                }
            }
        },
        
        showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        },

        async deleteTask(taskId) {
            if (!confirm('Are you sure you want to delete this task?')) {
                return;
            }

            try {
                const response = await fetch(`/tasks/${taskId}/delete`, {
                    method: 'DELETE',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    throw new Error('Failed to delete task');
                }

                // Remove task from UI
                for (const [status, tasks] of Object.entries(this.tasks)) {
                    const taskIndex = tasks.findIndex(t => t.id === taskId);
                    if (taskIndex > -1) {
                        tasks.splice(taskIndex, 1);
                        break;
                    }
                }

                this.updateTaskCounts();
                this.showNotification('Task deleted successfully', 'success');

            } catch (error) {
                console.error('Error deleting task:', error);
                this.showNotification('Failed to delete task. Please try again.', 'error');
            }
        }
    };
}

function taskModal() {
    return {
        isOpen: false,
        status: '',
        form: {
            title: '',
            description: '',
            project_id: '',
            priority: 'medium'
        },
        
        open(status) {
            this.status = status;
            this.isOpen = true;
        },
        
        close() {
            this.isOpen = false;
            this.resetForm();
        },
        
        resetForm() {
            this.form = {
                title: '',
                description: '',
                project_id: '',
                priority: 'medium'
            };
        },
        
        async submitTask() {
            try {
                const response = await fetch('/api/tasks', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        ...this.form,
                        status: this.status
                    })
                });
                
                if (!response.ok) {
                    throw new Error('Failed to create task');
                }
                
                const newTask = await response.json();
                
                // Add task to kanban board
                const kanbanComponent = document.querySelector('[x-data*="kanbanBoard"]')._x_dataStack[0];
                kanbanComponent.tasks[this.status].push(newTask);
                kanbanComponent.updateTaskCounts();
                
                this.close();
                kanbanComponent.showNotification('Task created successfully', 'success');
                
            } catch (error) {
                console.error('Error creating task:', error);
                alert('Failed to create task. Please try again.');
            }
        }
    };
}

function editTaskModal() {
    return {
        isOpen: false,
        currentTask: null,
        form: {
            title: '',
            description: '',
            priority: 'medium',
            status: ''
        },
        
        open(task) {
            this.currentTask = task;
            this.form = {
                title: task.title,
                description: task.description,
                priority: task.priority,
                status: task.status
            };
            this.isOpen = true;
        },
        
        close() {
            this.isOpen = false;
            this.currentTask = null;
            this.resetForm();
        },
        
        resetForm() {
            this.form = {
                title: '',
                description: '',
                priority: 'medium',
                status: ''
            };
        },
        
        async updateTask() {
            if (!this.currentTask) return;

            try {
                const formData = new FormData();
                formData.append('title', this.form.title);
                formData.append('description', this.form.description);
                formData.append('priority', this.form.priority);
                formData.append('status', this.form.status);

                const response = await fetch(`/tasks/${this.currentTask.id}/edit`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });
                
                if (!response.ok) {
                    throw new Error('Failed to update task');
                }
                
                const result = await response.json();
                
                if (!result.success) {
                    throw new Error('Failed to update task');
                }
                
                // Create updated task object with form data
                const updatedTask = { 
                    ...this.currentTask,
                    title: this.form.title,
                    description: this.form.description,
                    priority: this.form.priority,
                    status: this.form.status
                };
                
                // Update task in kanban board
                const kanbanComponent = document.querySelector('[x-data*="kanbanBoard"]')._x_dataStack[0];
                
                // Find and update the task in the current status
                for (const [status, tasks] of Object.entries(kanbanComponent.tasks)) {
                    const taskIndex = tasks.findIndex(t => t.id === this.currentTask.id);
                    if (taskIndex > -1) {
                        // If status changed, move task to new status
                        if (status !== this.form.status) {
                            tasks.splice(taskIndex, 1);
                            kanbanComponent.tasks[this.form.status].push(updatedTask);
                        } else {
                            // Update task in place
                            tasks[taskIndex] = updatedTask;
                        }
                        break;
                    }
                }
                
                kanbanComponent.updateTaskCounts();
                this.close();
                kanbanComponent.showNotification('Task updated successfully', 'success');
                
            } catch (error) {
                console.error('Error updating task:', error);
                this.showNotification('Failed to update task. Please try again.', 'error');
            }
        },

        showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `fixed top-4 right-4 px-4 py-2 rounded-md text-white z-50 ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            }`;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }
    };
}
</script>
