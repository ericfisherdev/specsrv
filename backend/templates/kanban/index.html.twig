{% extends 'base.html.twig' %}

{% block title %}Kanban Board - {{ parent() }}{% endblock %}

{% block body %}
<div class="max-w-full px-4 sm:px-6 lg:px-8 py-8">
    <!-- Enhanced Header -->
    <div class="mb-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between space-y-4 lg:space-y-0">
            <div class="space-y-2">
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Kanban Board</h1>
                <p class="text-gray-600 dark:text-gray-400">Manage your tasks across different stages</p>
                <div class="flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400">
                    <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v6a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                        <span x-text="`${getTotalTasks()} tasks`"></span>
                    </span>
                    <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Last updated: <span x-text="getLastUpdated()"></span>
                    </span>
                </div>
            </div>
            
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center space-y-3 sm:space-y-0 sm:space-x-4">
                <!-- Enhanced Quick Search -->
                <div class="relative" x-data="search()">
                    <input 
                        type="text" 
                        x-model="query"
                        @focus="focused = true"
                        @blur="setTimeout(() => focused = false, 200)"
                        data-search-input
                        placeholder="Search tasks... (⌘K)"
                        class="w-64 pl-10 pr-4 py-2.5 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all duration-200"
                    >
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <!-- Search results dropdown -->
                    <div x-show="focused && results.length > 0" 
                         x-transition
                         class="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl z-50 max-h-64 overflow-y-auto">
                        <template x-for="result in results.slice(0, 5)" :key="result.id">
                            <div @click="selectResult(result)" 
                                 class="px-4 py-3 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer border-b border-gray-100 dark:border-gray-600 last:border-b-0">
                                <div class="font-medium text-gray-900 dark:text-white" x-text="result.title"></div>
                                <div class="text-sm text-gray-500 dark:text-gray-400" x-text="result.project"></div>
                            </div>
                        </template>
                    </div>
                </div>
                
                <!-- Enhanced Project Filter -->
                <div class="relative" x-data="dropdown()">
                    <button @click="toggle()"
                            class="flex items-center px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-all duration-200">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                        </svg>
                        All Projects
                        <svg class="w-4 h-4 ml-2 transition-transform duration-200" :class="{ 'rotate-180': open }" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                    </button>
                    <div x-show="open" 
                         @click.away="close()"
                         x-transition
                         class="absolute top-full left-0 mt-1 w-56 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl z-50 py-1">
                        <a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
                            All Projects
                        </a>
                        <a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                            <span class="w-3 h-3 bg-green-500 rounded-full mr-3"></span>
                            Project Alpha
                        </a>
                        <a href="#" class="flex items-center px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700">
                            <span class="w-3 h-3 bg-purple-500 rounded-full mr-3"></span>
                            Project Beta
                        </a>
                    </div>
                </div>
                
                <!-- View Options -->
                <div class="flex rounded-lg border border-gray-300 dark:border-gray-600 overflow-hidden">
                    <button class="px-3 py-2 bg-primary-500 text-white text-sm font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2a2 2 0 002-2z"/>
                        </svg>
                    </button>
                    <button class="px-3 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 text-sm font-medium border-l border-gray-300 dark:border-gray-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="flex space-x-6 overflow-x-auto pb-6" x-data="kanbanBoard()">
        <!-- Backlog Column -->
        <div class="kanban-column flex-shrink-0" x-data="{ collapsed: false }" :class="collapsed ? 'w-16' : 'w-80'">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800" x-show="!collapsed">Backlog</h2>
                <h2 class="text-sm font-semibold text-gray-800 transform -rotate-90 whitespace-nowrap" x-show="collapsed">Backlog</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed" x-text="backlogTasks.length"></span>
                    <button @click="collapsed = !collapsed" class="text-gray-500 hover:text-gray-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 min-h-32" 
                 x-ref="backlogColumn" 
                 x-show="!collapsed" 
                 x-transition
                 @dragover.prevent
                 @drop.prevent="handleDrop('backlog', $event)">
                <template x-for="task in backlogTasks" :key="task.id">
                    <div class="kanban-card transition-all duration-200" 
                         :data-task-id="task.id"
                         draggable="true"
                         @dragstart="handleDragStart(task, $event)"
                         @dragend="handleDragEnd($event)">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-medium text-gray-900 flex-1" x-text="task.title"></h3>
                            <span 
                                class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2"
                                :class="task.priority_color"
                                x-text="task.priority_label"
                            ></span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1" x-text="task.description"></p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-xs text-gray-500" x-text="task.project"></span>
                            <div class="flex space-x-1">
                                <button class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                                <button class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
            <button class="w-full mt-4 p-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-500 hover:border-gray-400 hover:text-gray-600" x-show="!collapsed" x-transition @click="$dispatch('open-task-modal', { status: 'backlog' })">
                + Add Task
            </button>
        </div>

        <!-- Todo Column -->
        <div class="kanban-column flex-shrink-0" x-data="{ collapsed: false }" :class="collapsed ? 'w-16' : 'w-80'">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800" x-show="!collapsed">Todo</h2>
                <h2 class="text-sm font-semibold text-gray-800 transform -rotate-90 whitespace-nowrap" x-show="collapsed">Todo</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed" x-text="todoTasks.length"></span>
                    <button @click="collapsed = !collapsed" class="text-gray-500 hover:text-gray-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 min-h-32" 
                 x-ref="todoColumn" 
                 x-show="!collapsed" 
                 x-transition
                 @dragover.prevent
                 @drop.prevent="handleDrop('todo', $event)">
                <template x-for="task in todoTasks" :key="task.id">
                    <div class="kanban-card transition-all duration-200" 
                         :data-task-id="task.id"
                         draggable="true"
                         @dragstart="handleDragStart(task, $event)"
                         @dragend="handleDragEnd($event)">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-medium text-gray-900 flex-1" x-text="task.title"></h3>
                            <span 
                                class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2"
                                :class="task.priority_color"
                                x-text="task.priority_label"
                            ></span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1" x-text="task.description"></p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-xs text-gray-500" x-text="task.project"></span>
                            <div class="flex space-x-1">
                                <button class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                                <button class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
            <button class="w-full mt-4 p-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-500 hover:border-gray-400 hover:text-gray-600" x-show="!collapsed" x-transition @click="$dispatch('open-task-modal', { status: 'todo' })">
                + Add Task
            </button>
        </div>

        <!-- Working Column -->
        <div class="kanban-column flex-shrink-0 bg-blue-50 border-blue-200" x-data="{ collapsed: false }" :class="collapsed ? 'w-16' : 'w-80'">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-blue-800" x-show="!collapsed">Working</h2>
                <h2 class="text-sm font-semibold text-blue-800 transform -rotate-90 whitespace-nowrap" x-show="collapsed">Working</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-blue-200 text-blue-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed" x-text="workingTasks.length"></span>
                    <button @click="collapsed = !collapsed" class="text-blue-500 hover:text-blue-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 min-h-32" 
                 x-ref="workingColumn" 
                 x-show="!collapsed" 
                 x-transition
                 @dragover.prevent
                 @drop.prevent="handleDrop('in_progress', $event)">
                <template x-for="task in workingTasks" :key="task.id">
                    <div class="kanban-card border-blue-200 transition-all duration-200" 
                         :data-task-id="task.id"
                         draggable="true"
                         @dragstart="handleDragStart(task, $event)"
                         @dragend="handleDragEnd($event)">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-medium text-gray-900 flex-1" x-text="task.title"></h3>
                            <span 
                                class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2"
                                :class="task.priority_color"
                                x-text="task.priority_label"
                            ></span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1" x-text="task.description"></p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-xs text-gray-500" x-text="task.project"></span>
                            <div class="flex space-x-1">
                                <button class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                                <button class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Review Column -->
        <div class="kanban-column flex-shrink-0" x-data="{ collapsed: false }" :class="collapsed ? 'w-16' : 'w-80'">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800" x-show="!collapsed">Review</h2>
                <h2 class="text-sm font-semibold text-gray-800 transform -rotate-90 whitespace-nowrap" x-show="collapsed">Review</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed" x-text="reviewTasks.length"></span>
                    <button @click="collapsed = !collapsed" class="text-gray-500 hover:text-gray-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 min-h-32" 
                 x-ref="reviewColumn" 
                 x-show="!collapsed" 
                 x-transition
                 @dragover.prevent
                 @drop.prevent="handleDrop('review', $event)">
                <template x-for="task in reviewTasks" :key="task.id">
                    <div class="kanban-card transition-all duration-200" 
                         :data-task-id="task.id"
                         draggable="true"
                         @dragstart="handleDragStart(task, $event)"
                         @dragend="handleDragEnd($event)">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-medium text-gray-900 flex-1" x-text="task.title"></h3>
                            <span 
                                class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2"
                                :class="task.priority_color"
                                x-text="task.priority_label"
                            ></span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1" x-text="task.description"></p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-xs text-gray-500" x-text="task.project"></span>
                            <div class="flex space-x-1">
                                <button class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                                <button class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Done Column -->
        <div class="kanban-column flex-shrink-0 bg-green-50 border-green-200" x-data="{ collapsed: false }" :class="collapsed ? 'w-16' : 'w-80'">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-green-800" x-show="!collapsed">Done</h2>
                <h2 class="text-sm font-semibold text-green-800 transform -rotate-90 whitespace-nowrap" x-show="collapsed">Done</h2>
                <div class="flex items-center space-x-2">
                    <span class="bg-green-200 text-green-700 text-xs px-2 py-1 rounded-full" x-show="!collapsed" x-text="doneTasks.length"></span>
                    <button @click="collapsed = !collapsed" class="text-green-500 hover:text-green-700">
                        <svg class="w-4 h-4 transform transition-transform" :class="collapsed ? 'rotate-0' : 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="space-y-3 min-h-32" 
                 x-ref="doneColumn" 
                 x-show="!collapsed" 
                 x-transition
                 @dragover.prevent
                 @drop.prevent="handleDrop('completed', $event)">
                <template x-for="task in doneTasks" :key="task.id">
                    <div class="kanban-card border-green-200 opacity-75 transition-all duration-200" 
                         :data-task-id="task.id"
                         draggable="true"
                         @dragstart="handleDragStart(task, $event)"
                         @dragend="handleDragEnd($event)">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="font-medium text-gray-900 line-through flex-1" x-text="task.title"></h3>
                            <span 
                                class="priority-badge px-2 py-1 text-xs font-medium rounded-full ml-2 opacity-75"
                                :class="task.priority_color"
                                x-text="task.priority_label"
                            ></span>
                        </div>
                        <p class="text-sm text-gray-600 mt-1" x-text="task.description"></p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="text-xs text-gray-500" x-text="task.project"></span>
                            <div class="flex space-x-1">
                                <button class="text-blue-600 hover:text-blue-800 text-sm">Edit</button>
                                <button class="text-red-600 hover:text-red-800 text-sm">Delete</button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </div>

    <!-- Task Creation Modal -->
    <div x-data="taskModal()" x-show="isOpen" x-cloak 
         class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50"
         @open-task-modal.window="openModal($event.detail)"
         @keydown.escape.window="closeModal()">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" 
             @click.stop
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 transform scale-95"
             x-transition:enter-end="opacity-100 transform scale-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100 transform scale-100"
             x-transition:leave-end="opacity-0 transform scale-95">
            
            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-gray-200">
                <div class="flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-gray-900">Create New Task</h2>
                    <button @click="closeModal()" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Modal Body -->
            <div class="px-6 py-4">
                <form @submit.prevent="submitTask()" enctype="multipart/form-data">
                    <!-- Title -->
                    <div class="mb-6">
                        <label for="task-title" class="block text-sm font-medium text-gray-700 mb-2">Title</label>
                        <input 
                            type="text" 
                            id="task-title" 
                            x-model="form.title"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                            placeholder="Enter task title"
                            required
                        >
                    </div>

                    <!-- Description -->
                    <div class="mb-6">
                        <label for="task-description" class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                        <textarea 
                            id="task-description" 
                            x-model="form.description"
                            rows="4"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                            placeholder="Enter task description"
                        ></textarea>
                    </div>

                    <!-- Project Selection -->
                    <div class="mb-6">
                        <label for="task-project" class="block text-sm font-medium text-gray-700 mb-2">Project</label>
                        <select 
                            id="task-project" 
                            x-model="form.project_id"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                            required
                        >
                            <option value="">Select a project...</option>
                            <template x-for="project in projects" :key="project.id">
                                <option :value="project.id" x-text="project.name"></option>
                            </template>
                        </select>
                    </div>

                    <!-- Priority -->
                    <div class="mb-6">
                        <label for="task-priority" class="block text-sm font-medium text-gray-700 mb-2">Priority</label>
                        <select 
                            id="task-priority" 
                            x-model="form.priority"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        >
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>

                    <!-- File Upload -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Attach Files</label>
                        <div 
