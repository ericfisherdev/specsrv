<!DOCTYPE html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}SpecSrv - Task Management{% endblock %}</title>
        
        <!-- Favicon -->
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📋</text></svg>">
        
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="h-full bg-gray-100" x-data="{ showMobileMenu: false }">
        <!-- Navigation -->
        {% block navigation %}
        <nav class="bg-white shadow-sm border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <!-- Logo -->
                    <div class="flex items-center">
                        <a href="{{ path('app_dashboard') }}" class="text-xl font-bold text-gray-900">
                            📋 SpecSrv
                        </a>
                    </div>

                    <!-- Desktop Navigation -->
                    <div class="hidden md:flex items-center space-x-8">
                        <a href="{{ path('app_dashboard') }}" class="text-gray-700 hover:text-gray-900 px-3 py-2 text-sm font-medium">
                            Dashboard
                        </a>
                        <a href="{{ path('app_kanban') }}" class="text-gray-700 hover:text-gray-900 px-3 py-2 text-sm font-medium">
                            Kanban
                        </a>
                        <a href="{{ path('app_projects') }}" class="text-gray-700 hover:text-gray-900 px-3 py-2 text-sm font-medium">
                            Projects
                        </a>
                        
                        <!-- User Menu -->
                        <div class="relative" x-data="{ open: false }">
                            <button @click="open = !open" class="flex items-center text-sm text-gray-700 hover:text-gray-900">
                                <span>{{ app.user ? app.user.email : 'User' }}</span>
                                <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>
                            
                            <div x-show="open" @click.away="open = false" x-transition class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
                                <a href="{{ path('app_profile') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Profile</a>
                                <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Sign out</a>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile menu button -->
                    <div class="md:hidden">
                        <button @click="showMobileMenu = !showMobileMenu" class="text-gray-700 hover:text-gray-900">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Mobile Navigation -->
                <div x-show="showMobileMenu" x-transition class="md:hidden">
                    <div class="px-2 pt-2 pb-3 space-y-1">
                        <a href="{{ path('app_dashboard') }}" class="text-gray-700 hover:text-gray-900 block px-3 py-2 text-base font-medium">Dashboard</a>
                        <a href="{{ path('app_kanban') }}" class="text-gray-700 hover:text-gray-900 block px-3 py-2 text-base font-medium">Kanban</a>
                        <a href="{{ path('app_projects') }}" class="text-gray-700 hover:text-gray-900 block px-3 py-2 text-base font-medium">Projects</a>
                        <a href="{{ path('app_profile') }}" class="text-gray-700 hover:text-gray-900 block px-3 py-2 text-base font-medium">Profile</a>
                        <a href="{{ path('app_logout') }}" class="text-gray-700 hover:text-gray-900 block px-3 py-2 text-base font-medium">Sign out</a>
                    </div>
                </div>
            </div>
        </nav>
        {% endblock %}

        <!-- Flash Messages -->
        {% block flash_messages %}
        {% for label, messages in app.flashes %}
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
                {% for message in messages %}
                    <div class="alert alert-{{ label }} bg-{{ label == 'error' ? 'red' : label == 'success' ? 'green' : 'blue' }}-50 border border-{{ label == 'error' ? 'red' : label == 'success' ? 'green' : 'blue' }}-200 text-{{ label == 'error' ? 'red' : label == 'success' ? 'green' : 'blue' }}-800 px-4 py-3 rounded mb-4" role="alert">
                        {{ message }}
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
        {% endblock %}

        <!-- Main Content -->
        <main class="min-h-screen">
            {% block body %}{% endblock %}
        </main>

        <!-- Footer -->
        {% block footer %}
        <footer class="bg-white border-t border-gray-200 mt-auto">
            <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8">
                <p class="text-center text-sm text-gray-500">
                    &copy; {{ 'now'|date('Y') }} SpecSrv - Task Management System
                </p>
            </div>
        </footer>
        {% endblock %}
    </body>
</html>
