#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# PHP checks for backend (matching GitHub Actions CI)
echo "Running PHP checks for backend..."
(
  cd backend && \
  echo "→ Running PHPStan..." && \
  composer lint && \
  echo "→ Running PHP CS Fixer (check mode)..." && \
  composer cs-check && \
  echo "→ Running Rector (dry-run)..." && \
  ./vendor/bin/rector process --dry-run
) &&

# Go linting for CLI (if CLI directory exists and has Go files)
(
  if [ -d "cli" ] && [ -n "$(find cli -name "*.go" -type f 2>/dev/null)" ]; then
    echo "Running Go linting for CLI..."
    cd cli && \
    go fmt ./... && \
    go vet ./... && \
    go mod tidy
  fi
) &&

# GitHub Actions linting (non-blocking)
if command -v actionlint >/dev/null 2>&1; then
  actionlint .github/workflows/*.yml || true
fi

echo "✓ All pre-commit checks passed!"
