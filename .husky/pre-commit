#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# PHP linting for backend
cd backend && \
composer lint && \
cd .. && composer rector && \

# Go linting for CLI (if CLI directory exists and has Go files)
if [ -d "cli" ] && [ -n "$(find cli -name "*.go" -type f 2>/dev/null)" ]; then
  echo "Running Go linting for CLI..."
  cd cli && \
  go fmt ./... && \
  go vet ./... && \
  cd ..
fi && \

# GitHub Actions linting
actionlint .github/workflows/*.yml 2>/dev/null || true
